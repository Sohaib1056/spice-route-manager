# Server Configuration
PORT=5000
NODE_ENV=production

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Security
BCRYPT_SALT_ROUNDS=10

# Audit
AUDIT_LOG_RETENTION_DAYS=90

# CORS - Frontend URLs (comma-separated for multiple)
FRONTEND_URL=https://spice-route-manager.vercel.app

# Note: The backend automatically allows:
# - https://spice-route-manager.vercel.app
# - https://spice-route-manager-voem.vercel.app
# - All *.vercel.app preview deployments
# - localhost:3000, localhost:5173, localhost:5174
